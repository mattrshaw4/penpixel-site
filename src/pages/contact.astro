---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';
const diagnosisMailto = `mailto:${SITE.email}?subject=AI-Search%20Diagnosis%20request`;
---
<BaseLayout
  title="Contact Penpixel Creative | Initialize Your AI-Search Diagnosis"
  description="Start with the diagnosis. Tell us about your B2B SaaS brand, or book a call if you need more detail first."
>
  <main>
    <section class="mx-auto max-w-6xl px-6 pt-20 pb-16 md:pt-28">
      <p class="font-mono text-sm uppercase tracking-[0.2em] text-impact">// initialize diagnosis</p>
      <h1 class="mt-5 max-w-4xl text-5xl md:text-6xl">Start with the diagnosis.</h1>
      <p class="mt-6 max-w-2xl text-lg text-canvas/80">
        Two ways in, depending on where you are.
      </p>
    </section>

    <section class="border-t border-white/10">
      <div class="mx-auto grid max-w-6xl gap-px overflow-hidden border border-white/10 bg-white/10 px-0 sm:grid-cols-2">
        <div class="bg-authority p-8">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-impact">// ready to start</p>
          <h2 class="mt-3 text-2xl">Get the diagnosis</h2>
          <p class="mt-3 text-canvas/70">
            You already know AI search is leaving you out and you want the read on why.
            Send us your brand and your site, and we&rsquo;ll come back with where you stand.
          </p>
          <a href={diagnosisMailto} class="mt-6 inline-block bg-impact px-6 py-3 font-display font-bold text-canvas transition-opacity hover:opacity-90">Request the diagnosis</a>
        </div>
        <div class="bg-authority p-8">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-canvas/50">// need more detail</p>
          <h2 class="mt-3 text-2xl">Book a call</h2>
          <p class="mt-3 text-canvas/70">
            Want to understand the approach before committing? Book a short call and we&rsquo;ll
            walk through how it works and whether it fits.
          </p>
          <a href={SITE.booking} target="_blank" rel="noopener noreferrer" class="mt-6 inline-block border border-white/30 px-6 py-3 font-display font-bold text-canvas transition-colors hover:border-impact">Book a call</a>
        </div>
      </div>
    </section>

    <section class="border-t border-white/10">
      <div class="mx-auto max-w-6xl px-6 py-16">
        <p class="font-mono text-sm uppercase tracking-[0.2em] text-canvas/50">// direct</p>
        <p class="mt-4 text-canvas/70">
          Prefer email? Reach us at
          <a href={`mailto:${SITE.email}`} class="text-impact hover:underline">{SITE.email}</a>.
          Based in {SITE.locality}, {SITE.region}.
        </p>
        <p class="mt-6 font-mono text-xs text-canvas/40">// a full intake form is the next build phase</p>
      </div>
    </section>
  </main>
</BaseLayout>
