---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';

const services = [
  { tag: 'DIAGNOSIS', color: 'text-impact', title: 'AI Search Readiness Audit', desc: 'Where your brand is invisible, misread, or losing share in AI-driven discovery — and the prioritized fix.' },
  { tag: 'AUTHORITY', color: 'text-infra', title: 'Entity Management', desc: 'Synchronize your data across the web so models stop hallucinating or distrusting your brand.' },
  { tag: 'REMEDIATION', color: 'text-ai', title: 'Strategic Implementation', desc: 'Server-rendered HTML, structured data, machine-readable architecture. The technical fix.' },
  { tag: 'TRUST', color: 'text-success', title: 'Brand & Visual Authority', desc: 'Multimodal signals so the brand reads as credible to both people and machines.' },
];

const results = [
  { metric: '92.1%', label: 'AI citation growth', client: 'DT Heritage' },
  { metric: '1,500%', label: 'organic surge', client: 'Logistics entity build' },
  { metric: '44%', label: 'organic surge via identity recovery', client: 'The Alexander Group' },
];
---
<BaseLayout
  title="Penpixel Creative | AEO & AI Search Optimization for B2B SaaS"
  description="We rearchitect B2B SaaS digital estates to be cited, trusted, and recommended by AI agents. Get the diagnosis."
>
  <main>
    <!-- Hero -->
    <section class="mx-auto max-w-6xl px-6 pt-20 pb-24 md:pt-28">
      <p class="font-mono text-sm uppercase tracking-[0.2em] text-impact">// the invisible loss</p>
      <h1 class="mt-5 max-w-4xl text-5xl md:text-6xl">
        Stop Renting Your Visibility.<br />Own Your AI Share of Voice.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-canvas/80">
        Traditional SEO asks how to rank. We ask how your brand becomes the answer —
        and how AI agents complete the transaction.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="/contact" class="bg-impact px-6 py-3 font-display font-bold text-canvas transition-opacity hover:opacity-90">Get the Diagnosis</a>
        <a href="/services" class="border border-white/30 px-6 py-3 font-display font-bold text-canvas transition-colors hover:border-impact">See how it works</a>
      </div>
    </section>

    <!-- The shift -->
    <section class="border-t border-white/10">
      <div class="mx-auto max-w-6xl px-6 py-20">
        <p class="font-mono text-sm uppercase tracking-[0.2em] text-canvas/50">// the shift</p>
        <h2 class="mt-5 max-w-3xl text-3xl md:text-4xl">Buyers stopped clicking. Agents started deciding.</h2>
        <div class="mt-8 grid gap-8 md:grid-cols-3">
          <p class="text-canvas/70">An AI assistant now sits between your buyer and your site. It reads, ranks, and recommends before a human ever lands on a page.</p>
          <p class="text-canvas/70">If your architecture is built for human clicks, agents skip it. Your content exists, but it never enters the answer.</p>
          <p class="text-canvas/70">Conflicting data across the web makes models distrust your brand entirely — they cite a competitor instead, or hallucinate.</p>
        </div>
      </div>
    </section>

    <!-- What we do -->
    <section class="border-t border-white/10">
      <div class="mx-auto max-w-6xl px-6 py-20">
        <p class="font-mono text-sm uppercase tracking-[0.2em] text-canvas/50">// what we do</p>
        <h2 class="mt-5 text-3xl md:text-4xl">Four moves that make you the answer.</h2>
        <div class="mt-10 grid gap-px overflow-hidden border border-white/10 bg-white/10 sm:grid-cols-2">
          {services.map((s) => (
            <div class="bg-authority p-7">
              <p class:list={['font-mono text-xs uppercase tracking-[0.2em]', s.color]}>{s.tag}</p>
              <h3 class="mt-3 text-xl">{s.title}</h3>
              <p class="mt-2 text-canvas/70">{s.desc}</p>
            </div>
          ))}
        </div>
        <a href="/services" class="mt-8 inline-block font-mono text-sm text-impact hover:underline">See all services →</a>
      </div>
    </section>

    <!-- Proof -->
    <section class="border-t border-white/10">
      <div class="mx-auto max-w-6xl px-6 py-20">
        <p class="font-mono text-sm uppercase tracking-[0.2em] text-success">// proven results</p>
        <h2 class="mt-5 text-3xl md:text-4xl">The work shows up in the numbers.</h2>
        <div class="mt-10 grid gap-8 sm:grid-cols-3">
          {results.map((r) => (
            <div class="border-t-2 border-success/60 pt-5">
              <p class="font-mono text-4xl font-bold text-canvas md:text-5xl">{r.metric}</p>
              <p class="mt-2 text-canvas/80">{r.label}</p>
              <p class="mt-1 font-mono text-xs uppercase tracking-wider text-canvas/40">{r.client}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Closing CTA -->
    <section class="border-t border-white/10">
      <div class="mx-auto max-w-6xl px-6 py-24">
        <h2 class="max-w-3xl text-4xl md:text-5xl">Find out what the agents see when they look for you.</h2>
        <p class="mt-5 max-w-2xl text-lg text-canvas/70">It starts with the diagnosis: a clear read on where you're invisible, and what to fix first.</p>
        <a href="/contact" class="mt-8 inline-block bg-impact px-8 py-4 font-display text-lg font-bold text-canvas transition-opacity hover:opacity-90">Get the Diagnosis</a>
      </div>
    </section>
  </main>
</BaseLayout>
