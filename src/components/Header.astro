---
import { SITE, NAV } from '../consts';
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---
<header class="sticky top-0 z-50 border-b border-white/10 bg-authority/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4">
    <a href="/" class="flex items-center gap-3 font-display text-xl font-bold tracking-tight text-canvas">
      <img src="/images/penpixel-icon.webp" alt="Penpixel Creative" width="28" height="28" loading="eager" />
      <span>Penpixel <span class="text-canvas/50">Creative</span></span>
    </a>

    <!-- Desktop nav: unchanged -->
    <nav class="flex items-center gap-6 text-sm" aria-label="Primary">
      {NAV.map((item) => (
        <a
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
          class:list={[
            'hidden font-body transition-colors hover:text-canvas sm:inline',
            isActive(item.href) ? 'text-canvas' : 'text-canvas/60',
          ]}
        >{item.label}</a>
      ))}
      <a
        href="/contact"
        class="hidden bg-impact px-4 py-2 font-display text-sm font-bold text-canvas transition-opacity hover:opacity-90 sm:inline"
      >Get the Diagnosis</a>

      <!-- Mobile menu toggle: sm:hidden, only ever shown below the breakpoint -->
      <button
        id="mobile-nav-toggle"
        type="button"
        aria-controls="mobile-nav"
        aria-expanded="false"
        aria-label="Open menu"
        class="-mr-2 flex h-11 w-11 items-center justify-center text-canvas sm:hidden"
      >
        <svg id="icon-open" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
        <svg id="icon-close" class="hidden h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile nav panel: hidden by default, toggled by mobile-nav.js. sm:hidden as a hard backstop
       so it can never show on desktop even if JS state gets out of sync. -->
  <nav
    id="mobile-nav"
    class="hidden border-t border-white/10 bg-authority sm:hidden"
    aria-label="Mobile"
  >
    <div class="flex flex-col px-6 py-4">
      {NAV.map((item) => (
        <a
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
          class:list={[
            'border-b border-white/10 py-4 font-body text-base last:border-b-0',
            isActive(item.href) ? 'text-canvas' : 'text-canvas/70',
          ]}
        >{item.label}</a>
      ))}
      <a
        href="/contact"
        class="mt-4 bg-impact px-4 py-3 text-center font-display text-sm font-bold text-canvas"
      >Get the Diagnosis</a>
    </div>
  </nav>
</header>

<script is:inline src="/js/mobile-nav.js" defer></script>
