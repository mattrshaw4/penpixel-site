# Copy to .env for local dev (wrangler pages dev). NEVER commit the real .env.
# Production values live in the Cloudflare Pages dashboard (Settings > Environment
# variables), not in the repo.

# Turnstile SECRET key (dashboard > Turnstile > your widget).
# Local dev test secret (always passes): 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=

# Resend (resend.com) — free tier 3,000 emails/month.
RESEND_API_KEY=

# Where inquiries are delivered / verified sender they come from.
CONTACT_TO_EMAIL=deven@penpixelcreative.com
CONTACT_FROM_EMAIL=
